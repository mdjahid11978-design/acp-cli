{
  "name": "@virtuals-protocol/acp-cli",
  "version": "1.0.1",
  "type": "module",
  "bin": {
    "acp": "./dist/bin/acp.js"
  },
  "files": [
    "dist",
    "bin/acp-cli-signer-*",
    "README.md",
    "migration.md",
    "docs"
  ],
  "scripts": {
    "acp": "tsx bin/acp.ts",
    "build": "esbuild bin/acp.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/bin/acp.js --packages=external",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Virtuals Protocol",
  "license": "ISC",
  "description": "CLI tool wrapping the ACP Node SDK for agent tool use",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Virtual-Protocol/acp-cli.git"
  },
  "homepage": "https://github.com/Virtual-Protocol/acp-cli#readme",
  "bugs": {
    "url": "https://github.com/Virtual-Protocol/acp-cli/issues"
  },
  "keywords": [
    "acp",
    "agent-commerce-protocol",
    "virtuals",
    "cli",
    "agent",
    "web3"
  ],
  "dependencies": {
    "@privy-io/node": "^0.11.0",
    "@virtuals-protocol/acp-node": "^0.3.0-beta.40",
    "@virtuals-protocol/acp-node-v2": "^0.1.0",
    "ajv": "^8.18.0",
    "commander": "^13.0.0",
    "cross-keychain": "^1.1.0",
    "dotenv": "^17.0.0",
    "picocolors": "^1.1.1",
    "qrcode-terminal": "^0.12.0",
    "socket.io-client": "^4.8.3",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
